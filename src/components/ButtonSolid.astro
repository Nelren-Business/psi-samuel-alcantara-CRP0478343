---
// src/components/ButtonSolid.astro
import OptimizedImage from './OptimizedImage.astro'; // Nossa fonte única de verdade
import BgBotao from '../assets/bg-botao.webp'; // Verifique se o caminho bate com sua estrutura
import IconWhatsapp from './IconWhatsapp.astro'; // Ajuste o caminho se necessário

interface Props {
  href: string;
  text?: string;
  loading?: "eager" | "lazy";
  class?: string;
}

const { 
  href, 
  text = "Agendar Minha Consulta",
  loading = "lazy", 
  class: className = "" 
} = Astro.props;

// Lógica de CTO: Se a imagem precisa carregar rápido (eager), damos prioridade máxima na rede.
const fetchPriority = loading === "eager" ? "high" : "auto";
const decodingStrategy = loading === "eager" ? "sync" : "async";
---

<a class={`btn-solid ${className}`} href={href} target="_blank" rel="noopener noreferrer">
  <OptimizedImage 
    src={BgBotao} 
    alt="" 
    class="bg-botao-img"
    loading={loading} 
    fetchpriority={fetchPriority}
    decoding={decodingStrategy}
    aria-hidden="true"
  />
  <span>{text}</span>
  <IconWhatsapp />
</a>

<style>
  .bg-botao-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain; 
    object-position: center;
    z-index: -1; 
    pointer-events: none; 
  }
</style>