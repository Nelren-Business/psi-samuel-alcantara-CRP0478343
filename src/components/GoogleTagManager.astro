---
const gtmId = import.meta.env.PUBLIC_GTM_ID;
---

{gtmId && (
  <script is:inline define:vars={{ gtmId }}>
    let gtmLoaded = false;

    const loadGTM = () => {
      // Evita carregamento duplicado caso múltiplos eventos disparem juntos
      if (gtmLoaded) return;
      gtmLoaded = true;

      // Snippet oficial do GTM
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer', gtmId);

      // Limpa os event listeners para não consumir memória à toa após carregar
      const events = ['scroll', 'mousemove', 'touchstart', 'click', 'keydown'];
      events.forEach(event => window.removeEventListener(event, loadGTM));
    };

    // Adiciona os gatilhos de interação do usuário
    const events = ['scroll', 'mousemove', 'touchstart', 'click', 'keydown'];
    events.forEach(event => 
      window.addEventListener(event, loadGTM, { once: true, passive: true })
    );

    // DICA DE CTO: Fallback de segurança. 
    // Se o usuário não interagir com nada em 4 segundos, carrega o GTM mesmo assim.
    // Assim você foca no Lighthouse (que encerra o teste antes disso), mas não perde os dados do usuário que só está lendo.
    setTimeout(loadGTM, 4000);
  </script>
)}