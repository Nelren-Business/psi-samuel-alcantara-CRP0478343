---
// src/components/Instagram.astro
import OptimizedImage from '../OptimizedImage.astro'; // Nosso wrapper central assumindo o controle
import Slide1 from '../../assets/1-819x1024.jpg';
import Slide2 from '../../assets/2-819x1024.jpg';
import Slide3 from '../../assets/3-819x1024.jpg';
import Slide4 from '../../assets/4-819x1024.jpg';
import Slide5 from '../../assets/5-819x1024.jpg';
import Slide6 from '../../assets/6-819x1024.jpg';

// Importamos nossos módulos globais
import ButtonSolid from '../ButtonSolid.astro'; 
import { createWhatsAppUrl } from '../../utils/whatsapp';

// Centralizamos a geração do link
const whatsappLinkAgendar = createWhatsAppUrl("Olá, vim do site e gostaria de agendar uma consulta!");

const posts = [
  { img: Slide1, link: "https://www.instagram.com/p/DQuYpPDgcws/?img_index=1", alt: "Post Instagram 1" },
  { img: Slide2, link: "https://www.instagram.com/p/DQULJScDTeG/?img_index=1", alt: "Post Instagram 2" },
  { img: Slide3, link: "https://www.instagram.com/p/DReg584DcmZ/?img_index=1", alt: "Post Instagram 3" },
  { img: Slide4, link: "https://www.instagram.com/p/DS2lBIBjUNT/?img_index=1", alt: "Post Instagram 4" },
  { img: Slide5, link: "https://www.instagram.com/p/DSBNiusDf3O/?img_index=1", alt: "Post Instagram 5" },
  { img: Slide6, link: "https://www.instagram.com/p/DP8yIo2DXf3/?img_index=1", alt: "Post Instagram 6" }
];
---

<instagram-carousel-widget class="instagram-section">
  <div class="container">
    
    <header class="section-header">
      <h2>Conteúdos de saúde mental no meu Instagram</h2>
      <p>Conheça um pouco mais sobre mim e do meu trabalho como psicólogo no meu Instagram</p>
    </header>

    <div class="carousel-wrapper" id="instagram-carousel">
      
      <button class="carousel-arrow prev" aria-label="Slide anterior">
        <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M256 504C119 504 8 393 8 256S119 8 256 8s248 111 248 248-111 248-248 248zM142.1 273l135.5 135.5c9.4 9.4 24.6 9.4 33.9 0l17-17c9.4-9.4 9.4-24.6 0-33.9L226.9 256l101.6-101.6c9.4-9.4 9.4-24.6 0-33.9l-17-17c-9.4-9.4-24.6-9.4-33.9 0L142.1 239c-9.4 9.4-9.4 24.6 0 34z"></path>
        </svg>
      </button>

      <div class="carousel-track">
        {posts.map((post) => (
          <a href={post.link} target="_blank" rel="noopener noreferrer" class="carousel-slide" aria-label="Ver post no Instagram">
            <figure class="slide-inner">
              <OptimizedImage 
                src={post.img} 
                alt={post.alt} 
                width={819} 
                height={1024} 
                widths={[400, 600, 819]} 
                sizes="(max-width: 767px) 100vw, (max-width: 1024px) 50vw, 33vw"
                loading="lazy" 
                decoding="async" 
              />
              
              <div class="slide-overlay">
                <svg class="overlay-icon" aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
                  <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
                </svg>
              </div>
              
            </figure>
          </a>
        ))}
      </div>

      <button class="carousel-arrow next" aria-label="Próximo slide">
        <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M256 8c137 0 248 111 248 248S393 504 256 504 8 393 8 256 119 8 256 8zm113.9 231L234.4 103.5c-9.4-9.4-24.6-9.4-33.9 0l-17 17c-9.4 9.4-9.4 24.6 0 33.9L285.1 256 183.5 357.6c-9.4 9.4-9.4 24.6 0 33.9l17 17c9.4 9.4 24.6 9.4 33.9 0L369.9 273c9.4-9.4 9.4-24.6 0-34z"></path>
        </svg>
      </button>

    </div>

    <div class="carousel-pagination">
      {posts.map((_, index) => (
        <button 
          class={`dot ${index === 0 ? 'active' : ''}`} 
          data-target={index} 
          aria-label={`Ir para a página ${index + 1}`}>
        </button>
      ))}
    </div>

    <div class="action-buttons">
      
      <ButtonSolid href={whatsappLinkAgendar} />

      <a href="https://www.instagram.com/psi.samuelalcantara/" target="_blank" rel="noopener noreferrer" class="btn-instagram">
        <span class="btn-content">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
            <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
          </svg>
          <span>psi.samuelalcantara</span>
        </span>
      </a>
    </div>

  </div>
</instagram-carousel-widget>

<style>
  /* Adicionado para garantir que o Custom Element se comporte como um bloco */
  instagram-carousel-widget {
    display: block;
  }

  .instagram-section {
    padding: 80px 20px;
    background-color: var(--color-bg-light);
    overflow: hidden;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-header h2 {
    font-size: 46px;
    color: var(--color-primary);
    margin: 0 0 10px 0;
  }

  .section-header p {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-primary);
    margin: 0;
  }

  .carousel-wrapper {
    position: relative;
    width: 100%;
    margin-bottom: 20px; 
  }

  .carousel-track {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: 20px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-slide {
    flex: 0 0 calc(33.333% - 20px);
    scroll-snap-align: start;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .carousel-slide:hover {
    transform: translateY(-5px);
  }

  .slide-inner {
    margin: 0;
    border-radius: 5px;
    overflow: hidden;
    display: flex;
    position: relative;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .slide-inner :global(img) {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .slide-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none; 
  }

  .carousel-slide:hover .slide-overlay {
    opacity: 1;
  }

  .overlay-icon {
    width: 45px;
    height: 45px;
    fill: #FFFFFF;
    transform: translateY(15px);
    transition: transform 0.3s ease;
  }

  .carousel-slide:hover .overlay-icon {
    transform: translateY(0);
  }

  .carousel-arrow {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 10;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .carousel-arrow:hover {
    opacity: 0.7;
  }

  .carousel-arrow.prev { left: 10px; }
  .carousel-arrow.next { right: 10px; }

  .carousel-arrow svg {
    width: 40px;
    height: 40px;
    fill: #FFFFFF;
    filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.4));
  }

  .carousel-pagination {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 40px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-primary); 
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .dot.active {
    opacity: 1;
    transform: scale(1.2);
  }

  @media (min-width: 1025px) {
    .dot:nth-child(n+5) { display: none; }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    .dot:nth-child(n+6) { display: none; }
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
  }

  .btn-instagram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    background-color: var(--color-primary);
    border-radius: 5px;
    padding: 11px 13px;
    font-family: "Average Sans", sans-serif;
    font-size: 1.35em;
    font-weight: 400;
    color: #F9F2EC;
    fill: #F9F2EC;
    transition: filter 0.3s ease, background-color 0.3s ease;
  }

  .btn-instagram:hover { 
    filter: brightness(1.2);
    background-color: #0B4491D6; 
  }
  
  .btn-instagram .btn-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
  }

  .btn-instagram svg { width: 20px; height: 20px; }

  @keyframes elementorHint {
    0% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-50%, 0, 0); }
    100% { transform: translate3d(0, 0, 0); }
  }

  .animate-hint .carousel-slide {
    animation: elementorHint 2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (max-width: 1024px) {
    .section-header h2 { font-size: 38px; }
    .carousel-slide {
      flex: 0 0 calc(50% - 15px);
    }
  }

  @media (max-width: 767px) {
    .btn-instagram {
      padding: 8px 13px;
      font-size: 16px;
    }
    .carousel-track {
      gap: 0px;
      margin-bottom: -20px;
    }
    .instagram-section { padding: 60px 0px; }
    .section-header h2 { font-size: 32px; padding: 0px 15px; }
    .section-header p { font-size: 16px; padding: 15px 15px; }
    
    .carousel-slide { flex: 0 0 100%; }
    
    .carousel-arrow svg { width: 25px; height: 25px; }

    .action-buttons {
      flex-direction: column;
      gap: 15px;
      padding: 0 20px;
    }
  }
</style>

<script>
  class InstagramCarousel extends HTMLElement {
    constructor() {
      super();
      this.isDown = false;
      this.hasDragged = false;
      this.startX = 0;
      this.scrollLeft = 0;
      this.trackOffsetLeft = 0; // 🟢 NOVO: Variável de cache para o offset
      this.cachedSlideWidth = 0;
      this.cachedClientWidth = 0;
      this.isTicking = false;
      
      this.updateDimensions = this.updateDimensions.bind(this);
      this.handleScrollUpdates = this.handleScrollUpdates.bind(this);
    }

    connectedCallback() {
      this.track = this.querySelector('.carousel-track');
      this.prevBtn = this.querySelector('.carousel-arrow.prev');
      this.nextBtn = this.querySelector('.carousel-arrow.next');
      this.dots = this.querySelectorAll('.dot');
      this.links = this.querySelectorAll('.carousel-slide');

      if (!this.track) return;

      this.setupEventListeners();
      this.setupIntersectionObserver();
      
      requestAnimationFrame(this.updateDimensions);
    }

    disconnectedCallback() {
      window.removeEventListener('resize', this.updateDimensions);
      if (this.observer) this.observer.disconnect();
    }

    setupEventListeners() {
      window.addEventListener('resize', () => {
        window.requestAnimationFrame(this.updateDimensions);
      }, { passive: true });

      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', () => {
          this.track.scrollBy({ left: -this.cachedSlideWidth, behavior: 'smooth' });
        });
      }

      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', () => {
          this.track.scrollBy({ left: this.cachedSlideWidth, behavior: 'smooth' });
        });
      }

      this.dots.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          const targetIndex = parseInt(e.target.getAttribute('data-target') || '0');
          this.track.scrollTo({ left: targetIndex * this.cachedSlideWidth, behavior: 'smooth' });
        });
      });

      this.track.addEventListener('scroll', () => {
        if (!this.isTicking) {
          window.requestAnimationFrame(this.handleScrollUpdates);
          this.isTicking = true;
        }
      }, { passive: true });

      // 🟢 CORREÇÃO DE PERFORMANCE: Lógica de Drag refatorada
      this.track.addEventListener('mousedown', (e) => {
        this.isDown = true;
        this.hasDragged = false; 
        
        // 1. FASE DE LEITURA (Cache)
        this.trackOffsetLeft = this.track.offsetLeft;
        this.startX = e.pageX - this.trackOffsetLeft;
        this.scrollLeft = this.track.scrollLeft;
        
        // 2. FASE DE ESCRITA (Isolada)
        requestAnimationFrame(() => {
          this.track.style.scrollSnapType = 'none'; 
          this.track.style.cursor = 'grabbing';
        });
      });

      window.addEventListener('mouseup', () => {
        if(!this.isDown) return;
        this.isDown = false;
        this.track.style.scrollSnapType = 'x mandatory';
        this.track.style.cursor = 'auto';
      });

      this.track.addEventListener('mousemove', (e) => {
        if (!this.isDown) return;
        e.preventDefault();
        
        // 🟢 ZERO LEITURAS DE DOM: Usando o valor em cache
        const x = e.pageX - this.trackOffsetLeft;
        const walk = (x - this.startX) * 1.5; 
        
        if (Math.abs(walk) > 5) {
          this.hasDragged = true;
        }
        
        this.track.scrollLeft = this.scrollLeft - walk; 
      });

      this.links.forEach(link => {
        link.addEventListener('click', (e) => {
          if (this.hasDragged) {
            e.preventDefault(); 
            e.stopPropagation();
          }
        });
      });
    }

    updateDimensions() {
      const slide = this.track.querySelector('.carousel-slide');
      this.cachedSlideWidth = slide ? slide.offsetWidth + 30 : 0; 
      this.cachedClientWidth = this.track.clientWidth;
      this.handleScrollUpdates();
    }

    handleScrollUpdates() {
      if (this.cachedSlideWidth === 0) {
        this.isTicking = false;
        return; 
      }

      const scrollPosition = this.track.scrollLeft;
      const slidesPerView = Math.round(this.cachedClientWidth / this.cachedSlideWidth);
      const maxIndex = this.dots.length - slidesPerView;
      let currentIndex = Math.round(scrollPosition / this.cachedSlideWidth);
      
      if (currentIndex > maxIndex) currentIndex = maxIndex;

      requestAnimationFrame(() => {
        this.dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === currentIndex);
        });
      });

      this.isTicking = false;
    }

    setupIntersectionObserver() {
      let animationExecuted = false; 
      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (animationExecuted) return; 
          if (entry.isIntersecting) {
            animationExecuted = true; 
            this.track.classList.add('animate-hint');
            setTimeout(() => { this.track.classList.remove('animate-hint'); }, 2500); 
            this.observer.disconnect(); 
          }
        });
      }, { threshold: 0.6 });

      this.observer.observe(this.track);
    }
  }

  customElements.define('instagram-carousel-widget', InstagramCarousel);
</script>