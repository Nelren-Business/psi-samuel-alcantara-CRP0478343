---
// src/components/Instagram.astro
import OptimizedImage from '../OptimizedImage.astro';
import BaseCarousel from '../BaseCarousel.astro';
import ButtonSolid from '../ButtonSolid.astro'; 
import { createWhatsAppUrl } from '../../utils/whatsapp';

import Slide1 from '../../assets/1-819x1024.jpg';
import Slide2 from '../../assets/2-819x1024.jpg';
import Slide3 from '../../assets/3-819x1024.jpg';
import Slide4 from '../../assets/4-819x1024.jpg';
import Slide5 from '../../assets/5-819x1024.jpg';
import Slide6 from '../../assets/6-819x1024.jpg';

import PranchetaFinal from '../../assets/Prancheta-Final.png';

const whatsappLinkAgendar = createWhatsAppUrl("Olá, vim do site e gostaria de agendar uma consulta!");

const posts = [
  { img: Slide1, link: "https://www.instagram.com/p/DQuYpPDgcws/?img_index=1", alt: "Post Instagram 1" },
  { img: Slide2, link: "https://www.instagram.com/p/DQULJScDTeG/?img_index=1", alt: "Post Instagram 2" },
  { img: Slide3, link: "https://www.instagram.com/p/DReg584DcmZ/?img_index=1", alt: "Post Instagram 3" },
  { img: Slide4, link: "https://www.instagram.com/p/DS2lBIBjUNT/?img_index=1", alt: "Post Instagram 4" },
  { img: Slide5, link: "https://www.instagram.com/p/DSBNiusDf3O/?img_index=1", alt: "Post Instagram 5" },
  { img: Slide6, link: "https://www.instagram.com/p/DP8yIo2DXf3/?img_index=1", alt: "Post Instagram 6" }
];
---

<div>
  <OptimizedImage 
    src={PranchetaFinal} 
    alt="" 
    class="bg-section-process" 
    loading="lazy" 
    decoding="async" 
    aria-hidden="true" 
  />
</div>

<section class="instagram-section">
  <div class="container">
    
    <BaseCarousel itemCount={posts.length} gap="30px">
      
      <header class="section-header" slot="header">
        <h2>Conteúdos de saúde mental no meu Instagram</h2>
        <p>Conheça um pouco mais sobre mim e do meu trabalho como psicólogo no meu Instagram</p>
      </header>

      {posts.map((post) => (
        <a href={post.link} target="_blank" rel="noopener noreferrer" class="carousel-slide" aria-label="Ver post no Instagram">
          <figure class="slide-inner">
            <OptimizedImage 
              src={post.img} 
              alt={post.alt} 
              width={819} 
              height={1024} 
              widths={[400, 600, 819]} 
              sizes="(max-width: 767px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading="lazy" 
              decoding="async" 
            />
            
            <div class="slide-overlay">
              <svg class="overlay-icon" aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
                <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
              </svg>
            </div>
            
          </figure>
        </a>
      ))}

      <div class="action-buttons" slot="footer">
        <ButtonSolid href={whatsappLinkAgendar} />

        <a href="https://www.instagram.com/psi.samuelalcantara/" target="_blank" rel="noopener noreferrer" class="btn-instagram">
          <span class="btn-content">
            <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
              <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
            </svg>
            <span>psi.samuelalcantara</span>
          </span>
        </a>
      </div>

    </BaseCarousel>

  </div>
</section>

<style>
  .instagram-section {
    padding: 120px 20px 40px 20px;
    background-color: var(--color-bg-light);
    overflow: hidden;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-header h2 {
    font-size: 46px;
    color: var(--color-primary);
    margin: 0 0 10px 0;
  }

  .section-header p {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-primary);
    margin: 0;
  }

  .carousel-slide {
    flex: 0 0 calc(33.333% - 20px);
    scroll-snap-align: start;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .carousel-slide:hover {
    transform: translateY(-5px);
  }

  .slide-inner {
    margin: 0;
    border-radius: 5px;
    overflow: hidden;
    display: flex;
    position: relative;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .slide-inner :global(img) {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .slide-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none; 
  }

  .carousel-slide:hover .slide-overlay {
    opacity: 1;
  }

  .overlay-icon {
    width: 45px;
    height: 45px;
    fill: #FFFFFF;
    transform: translateY(15px);
    transition: transform 0.3s ease;
  }

  .carousel-slide:hover .overlay-icon {
    transform: translateY(0);
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
  }

  .btn-instagram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    background-color: var(--color-primary);
    border-radius: 5px;
    padding: 11px 13px;
    font-family: "Average Sans", sans-serif;
    font-size: 1.35em;
    font-weight: 400;
    color: #F9F2EC;
    fill: #F9F2EC;
    transition: filter 0.3s ease, background-color 0.3s ease;
  }

  .btn-instagram:hover { 
    filter: brightness(1.2);
    background-color: #0B4491D6; 
  }
  
  .btn-instagram .btn-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
  }

  .btn-instagram svg { width: 20px; height: 20px; }

  @media (max-width: 1024px) {
    .section-header h2 { font-size: 38px; }
    .carousel-slide { flex: 0 0 calc(50% - 15px); }
  }

  @media (max-width: 767px) {
    .instagram-section { padding: 60px 0px; }
    .section-header h2 { font-size: 32px; padding: 0px 15px; }
    .section-header p { font-size: 16px; padding: 15px 15px; }
    
    /* Remove o gap injetado no component base para aparelhos mobile */
    base-carousel { --carousel-gap: 0px !important; }
    .carousel-slide { flex: 0 0 100%; }
    
    .btn-instagram {
      padding: 8px 13px;
      font-size: 16px;
    }

    .action-buttons {
      flex-direction: column;
      gap: 15px;
      padding: 0 20px;
    }
  }
</style>