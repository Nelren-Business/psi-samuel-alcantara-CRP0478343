---
// src/components/AboutUs.astro
import { Image } from 'astro:assets';
import TerapiaBG from '../../assets/Terapia-2.svg';
import PaperBg from '../../assets/Vector-1-1.png';
import ButtonBg from '../../assets/Vector-1-2.png';
import PhotoBg from '../../assets/DOBRA-6-02.webp';
import { createWhatsAppUrl } from '../../utils/whatsapp'; // Mantemos a lógica centralizada

// Geramos o link de forma dinâmica
const whatsappLinkAgendar = createWhatsAppUrl("Olá, vim do site e gostaria de agendar uma consulta!");
---

<section class="about-section" id="about">
  <Image 
    class="bg-terapia" 
    src={TerapiaBG} 
    alt="" 
    aria-hidden="true" 
    loading="lazy" 
  />

  <div class="container">
    <div class="text-column">
      <h2 class="title">
        Pode me chamar de Samuel! Um psicólogo <span class="pink">LGBTQIA+</span>
      </h2>

      <div class="paper-box">
        <Image 
          src={PaperBg} 
          alt="" 
          class="bg-paper-img" 
          aria-hidden="true"
          loading="lazy"
        />
        
        <p class="description">
          Como psicólogo e parte da comunidade LGBTQIA+, uno a ciência da psicologia a uma escuta sensível e empática às nossas vivências. Meu compromisso é criar um espaço seguro e colaborativo para você ser quem é, explorando suas questões para construir uma vida mais autêntica.
        </p>

        <ul class="icon-list">
          <li>
            <svg class="bullet" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg>
            <span>Bacharel - Universidade Federal de Juiz de Fora (UFJF)</span>
          </li>
          <li>
            <svg class="bullet" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg>
            <span>Pós-graduando - Psicopatologia, Grupo PBE e FLNC.</span>
          </li>
          <li>
            <svg class="bullet" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 8C119 8 8 119 8 256s111 248 248 248-111 248-248S393 8 256 8z"></path></svg>
            <span>Pós-graduando - Piscoterapia para Adultos Neurodivergentes, Sínteses</span>
          </li>
          <li>
            <svg class="bullet" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg>
            <span>Formação em Terapia Cognitivo-Comportamental (TCC), Grupo PBE e FLNC</span>
          </li>
          <li>
            <svg class="bullet" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8z"></path></svg>
            <span>Formação em Psicoterapia Baseada em Evidências - InPBE</span>
          </li>
        </ul>
      </div>

      <a 
        href={whatsappLinkAgendar} 
        class="whatsapp-btn" 
        target="_blank" 
        rel="noopener noreferrer"
      >
        <Image 
          src={ButtonBg} 
          alt="" 
          class="bg-button-img" 
          aria-hidden="true"
          loading="lazy"
        />
        <svg class="whatsapp-icon" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path></svg>
        <span class="btn-text">Agendar Minha Consulta</span>
      </a>
    </div>

    <div class="image-column">
      <div class="photo-wrapper">
        <Image 
          src={PhotoBg} 
          alt="Foto Samuel" 
          class="photo-img"
          loading="lazy" 
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* Base e Tipografia Global da Seção */
  .about-section {
    position: relative;
    padding: 300px 20px 40px 20px;
    background: transparent;
    overflow: hidden;
  }

  .bg-terapia {
    position: absolute;
    top: 150px;
    left: 0;
    width: 10%;
    z-index: 0;
    pointer-events: none;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    z-index: 2;
  }

  /* --- Coluna Esquerda (Textos) --- */
  .text-column {
    width: calc(100% - 500px);
    max-width: 628px;
    padding-right: 60px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .title {
    font-size: 41px;
    font-weight: 500;
    line-height: 1.3em;
    color: var(--color-primary); 
    margin: 0 0 20px 0;
  }

  .title .pink {
    color: var(--color-accent);
  }

  .paper-box {
    position: relative; 
    padding: 50px 40px 70px 40px;
    margin: 0;
    width: 100%;
  }

  .bg-paper-img {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 110%;
    height: 100%;
    object-fit: fill; 
    z-index: -1;
    pointer-events: none;
  }

  .description {
    font-weight: 500;
    color: var(--color-primary);
    margin: 0 0 20px 0;
  }

  .icon-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .icon-list li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding-bottom: 5px;
    margin-top: 5px;
  }

  .bullet {
    width: 5px;
    height: 5px;
    fill: var(--color-primary);
    margin-top: 10px;
    flex-shrink: 0;
  }

  .icon-list span {
    font-weight: 500;
    color: var(--color-primary);
  }

  /* --- Botão Restaurado Original --- */
  .whatsapp-btn {
    display: inline-flex;
    flex-direction: row-reverse;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: #F9F2EC;
    padding: 20px 30px 20px 30px;
    text-decoration: none;
    margin-top: -50px;
    margin-left: 15px;
    position: relative;
    z-index: 3;
    transition: filter 0.3s ease;
  }

  .bg-button-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: fill;
    z-index: -1;
    pointer-events: none;
  }

  .whatsapp-btn:hover {
    filter: brightness(1.2);
  }

  .btn-text {
    font-family: var(--font-heading);
    font-size: 23px;
    font-weight: 400;
  }

  .whatsapp-icon {
    width: 22px;
    height: 22px;
    fill: #F9F2EC;
  }

  /* --- Coluna Direita (Imagem como Fundo) --- */
  .image-column {
    width: 500px;
    position: relative;
  }

  .photo-wrapper {
    width: 300%;
    aspect-ratio: 1831 / 1450; 
    margin-top: -80%; 
    margin-left: -10%;
    position: relative;
  }

  .photo-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* --- Responsividade Desktop Menor / Tablet --- */
  @media (max-width: 1024px) {
    .container {
      justify-content: center;
      align-items: center;
    }
    
    .text-column {
      width: 100%;
      max-width: 100%;
      padding-right: 0;
      align-items: center;
    }

    .image-column {
      width: 100%;
      order: -1;
      margin-bottom: 40px;
    }

    .photo-wrapper {
      width: 140%;
      margin-top: -10%;
      margin-left: -20%;
    }

    .title {
      text-align: left;
    }
  }

  /* --- Responsividade Mobile --- */
  @media (max-width: 767px) {
    .about-section {
      padding: 0 0 0 0;
      margin-bottom: 100px;
    }

    .title {
      font-size: 32px;
      padding: 0 20px;
    }

    .paper-box {
      padding: 80px 20px 80px 20px;
    }

    .bg-paper-img {
      width: 100%;
      object-fit: cover;
    }

    .photo-wrapper {
      width: 240%;
      margin-top: -80px;
      margin-left: 0; 
    }

    .description {
      font-size: 15px;
    }

    .icon-list span {
      font-size: 16px;
    }

    /* Ajuste do botão restaurado */
    .whatsapp-btn {
      padding: 20px 30px;
      margin-left: 0;
    }

    .btn-text {
      font-size: 18px;
    }

    .image-column {
      margin-bottom: 20px;
    }
    
    .bg-terapia {
      display: none;
    }
  }
</style>