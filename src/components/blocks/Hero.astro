---
// src/components/Hero.astro
import { Image, getImage } from 'astro:assets'; // <-- Trocamos Picture por getImage
import TerapiaSVG from '../../assets/Terapia.svg';
import BgHeroDesktop from '../../assets/bg-hero-01.webp';
import BgHeroMobile from '../../assets/bg-mobile-01.webp';
import BgBotao from '../../assets/bg-botao.webp';
import IconWhatsapp from './IconWhatsapp.astro';

const phone = "5537998164092";

const createWhatsAppUrl = (text: string) => {
  const params = new URLSearchParams({ phone, text });
  return `https://api.whatsapp.com/send/?${params.toString()}`;
};

const whatsappLink = createWhatsAppUrl("Olá, vim do site e gostaria de tirar algumas dúvidas!");
const whatsappLinkAgendar = createWhatsAppUrl("Olá, vim do site e gostaria de agendar uma consulta!");

// --- MUDANÇA AQUI: Processando as imagens manualmente para o Art Direction ---
const optimizedMobileBg = await getImage({ src: BgHeroMobile, format: 'webp' });
const optimizedDesktopBg = await getImage({ src: BgHeroDesktop, format: 'webp' });
---

<section class="hero-section">
  
  <picture>
    <source media="(max-width: 1024px)" srcset={optimizedMobileBg.src} />
    <img 
      src={optimizedDesktopBg.src} 
      alt="Fundo do ambiente terapêutico" 
      class="hero-bg"
      fetchpriority="high"
      loading="eager"
    />
  </picture>

  <Image 
    src={TerapiaSVG} 
    class="deco-image" 
    alt="Ilustração Terapia"
    loading="eager"
  />

  <div class="hero-content">
    <hgroup>
      <p class="subtitle">
        <span class="dest">Psicólogo Online LGBTQIA+ | CRP: 04/78343</span>
      </p>
      <h1 class="title">
        Sua história merece ser compreendida. Vamos conversar?
      </h1>
    </hgroup>

    <p class="description">
      <b>Prazer! Meu nome é Samuel, psicólogo LGBTQIA+ com atendimento online, </b>formado pela UFJF e pós-graduando. Sempre valorizei o privilégio de me conectar com pessoas, entender suas histórias e contribuir em seus processos terapêuticos. Que tal darmos o nosso primeiro passo juntos?
      <br>
      <a class="btn-outline" href={whatsappLink} target="_blank" rel="noopener noreferrer">
        <span>Vamos conversar!</span>
        <IconWhatsapp/>
      </a>   
    </p>

    <div class="hero-buttons">
      <a class="btn-solid" href={whatsappLinkAgendar} target="_blank" rel="noopener noreferrer">
        <Image 
          src={BgBotao} 
          alt="Textura de fundo do botão" 
          class="bg-botao-img"
          loading="eager" 
        />
        <span>Agendar Minha Consulta</span>
        <IconWhatsapp/>
      </a>
    </div>
  </div>
</section>

<style>
  /* --- O resto do seu CSS continua EXATAMENTE igual --- */
  .hero-section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    min-height: 800px;
    padding: 90px 20px 100px 20px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    z-index: 0;
  }

  .deco-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 15%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
    z-index: 2;
    max-width: 1140px;
    margin: 0 auto;
    width: 100%;
  }

  .subtitle {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 400;
    line-height: 1.1em;
    color: var(--color-accent);
    margin: -15px 0 30px 0;
  }

  .dest {
    background-color: #d9488115;
    padding: 0px 6px;
    position: relative;
    display: inline-block;
    border-left: 1px solid var(--color-accent);
    border-right: 1px solid var(--color-accent);
  }
  
  .dest::before, .dest::after {
    content: "";
    position: absolute;
    background: var(--color-accent);
    width: 6px;
    height: 6px;
    border-radius: 100px;
  }
  
  .dest::before { top: -3px; left: -4px; }
  .dest::after { bottom: -3px; right: -4px; }

  .title {
    max-width: 580px;
    font-family: var(--font-heading);
    font-size: 44px;
    font-weight: 500;
    line-height: 1.2em;
    color: var(--color-primary);
    margin: 0;
  }

  .description {
    max-width: 434px;
    font-family: var(--font-text);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5em;
    color: var(--color-primary);
    padding-left: 20px;
    border-left: 1px solid var(--color-primary);
    margin: 0;
  }
  
  .description b {
    font-weight: 600;
  }

  .hero-buttons {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .btn-outline, .btn-solid {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-outline {
    background-color: rgba(252, 163, 185, 0.23);
    font-family: var(--font-text);
    font-size: 16px;
    color: var(--color-primary);
    margin-top: 12px;   
    margin-bottom: 8px; 
    fill: var(--color-primary);
    border: 1px solid rgba(217, 72, 129, 0.42);
    padding: 8px 8px;
  }
  
  .btn-outline:hover {
    background-color: rgba(252, 163, 185, 0.4);
  }

  .btn-solid {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-bg-light);
    fill: var(--color-bg-light);
    padding: 31px 40px 32px 85px; 
    background-color: transparent; 
    position: relative;
  }
  
  .btn-solid:hover {
    filter: brightness(1.2);
  }

  .bg-botao-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain; 
    object-position: center;
    z-index: -1; 
    pointer-events: none; 
  }

  @media (max-width: 1024px) {
    .hero-section {
      align-items: center;
      padding-top: max(60vw, 400px); 
      min-height: auto;
    }

    .hero-bg {
      object-fit: contain;
      object-position: top;
    }
    
    .hero-content {
      text-align: center;
      align-items: center;
      text-wrap: balance;
    }

    .description {
      padding-left: 0;
      border-left: none;
    }

    .hero-buttons {
      align-items: center;
      width: 100%;
    }

    .btn-solid {
      max-width: 300px;
      width: 100%;
      padding: 25px 10px 28px 40px;
      justify-content: center;
    }
  }

  @media (max-width: 767px) {
    .hero-section {
      padding-top: max(105vw, 250px);
    }

    .title {
      font-size: 2em;
      line-height: 1.1em;
      margin-top: -10px;
    }

    .subtitle {
      font-size: 1em;
    }

    .description {
      font-size: 0.9em;
      margin-top: -10px;
    }

    .btn-outline {
      margin-top: 25px;
      margin-bottom: 0px;
      font-size: 0.9em;
    }

    .btn-solid {
      font-size: 1em;
      margin-top: -10px;
      margin-bottom: 50px;
    }
  }
</style>