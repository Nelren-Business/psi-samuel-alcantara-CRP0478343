---
import { getImage } from 'astro:assets'; 
import TerapiaSVG from '../../assets/Terapia.svg';
import BgHeroDesktop from '../../assets/bg-hero-01.webp';
import BgHeroMobile from '../../assets/bg-mobile-01.webp';
import IconWhatsapp from '../IconWhatsapp.astro';
import ButtonSolid from '../ButtonSolid.astro';
import { createWhatsAppUrl } from '../../utils/whatsapp';

const whatsappLink = createWhatsAppUrl("Olá, vim do site e gostaria de tirar algumas dúvidas!");
const whatsappLinkAgendar = createWhatsAppUrl("Olá, vim do site e gostaria de agendar uma consulta!");

const optimizedMobileBg = await getImage({ src: BgHeroMobile, format: 'avif' });
const optimizedDesktopBg = await getImage({ src: BgHeroDesktop, format: 'avif' });
---

<section class="hero-section">
  
  <picture>
    <source media="(max-width: 1024px)" srcset={optimizedMobileBg.src} type="image/avif" />
    <source media="(max-width: 1024px)" srcset={BgHeroMobile.src} type="image/webp" />
    
    <source media="(min-width: 1025px)" srcset={optimizedDesktopBg.src} type="image/avif" />
    <img 
      src={BgHeroDesktop.src} 
      alt="Fundo do ambiente terapêutico" 
      class="hero-bg"
      fetchpriority="high"
      loading="eager"
      decoding="async" 
      /* Mudança 2: Previne layout shifts e ajuda no cálculo de renderização */
      width={BgHeroDesktop.width}
      height={BgHeroDesktop.height}
    />
  </picture>

  <img 
    src={TerapiaSVG.src} 
    class="deco-image" 
    alt="Ilustração Terapia"
    loading="eager" 
    fetchpriority="high"
    decoding="async"
    aria-hidden="true"
  />

  <div class="hero-content">
    <hgroup>
      <p class="text-subtitle">
        <span class="tag-highlight">Psicólogo Online LGBTQIA+ | CRP: 04/78343</span>
      </p>
      <h1>
        Sua história merece ser compreendida. Vamos conversar?
      </h1>
    </hgroup>

    <div class="description-wrapper">
      <p class="description">
        <b>Prazer! Meu nome é Samuel, psicólogo LGBTQIA+ com atendimento online, </b>formado pela UFJF e pós-graduando. Sempre valorizei o privilégio de me conectar com pessoas, entender suas histórias e contribuir em seus processos terapêuticos. Que tal darmos o nosso primeiro passo juntos?
      </p>
      
      <a class="btn-outline" href={whatsappLink} target="_blank" rel="noopener noreferrer">
        <span>Vamos conversar!</span>
        <IconWhatsapp/>
      </a>   
    </div>

    <div class="hero-buttons">
      <ButtonSolid href={whatsappLinkAgendar} loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    min-height: 800px;
    padding: 80px 20px 100px 20px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    z-index: 0;
  }

  .deco-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 15%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
    z-index: 2;
    max-width: 1140px;
    margin: 0 auto;
    width: 100%;
  }

  h1 {
    max-width: 580px;
    margin: 0;
  }

  .description-wrapper {
    max-width: 454px; 
    padding-left: 20px;
    border-left: 1px solid var(--color-primary);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 15px;
    padding-bottom: 5px;
  }

  .description {
    color: var(--color-primary);
    margin: 0;
  }
  
  .description b {
    font-weight: 600;
  }

  .hero-buttons {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (max-width: 1024px) {
    .description-wrapper {
      padding-left: 0;
      border-left: none;
      align-items: center;
    }

    .hero-section {
      align-items: center;
      padding-top: max(60vw, 400px); 
      min-height: auto;
    }

    .hero-bg {
      object-fit: contain;
      object-position: top;
    }
    
    .hero-content {
      text-align: center;
      align-items: center;
      text-wrap: balance;
    }

    h1 {
      max-width: 100%;
    }

    .description {
      margin-top: -10px;
      padding-left: 0;
      border-left: none;
    }

    .hero-buttons {
      align-items: center;
      width: 100%;
    }
  }

  @media (max-width: 767px) {
    .btn-outline {
      margin-top: 10px;
      margin-bottom: -20px;
    }

    .hero-section {
      padding-top: max(105vw, 250px);
      padding-bottom: 50px;
    }
  }
</style>