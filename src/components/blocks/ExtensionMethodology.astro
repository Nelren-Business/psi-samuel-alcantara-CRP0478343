---
// src/components/ExtensionMethodology.astro
import { Image } from 'astro:assets';
import Vector10 from '../../assets/Vector-10.svg';
import BluePin2 from '../../assets/Blue-Pin-2.svg';
import BluePin3 from '../../assets/Blue-Pin-3.svg';

// Novas importações de background
import BgDivisor from '../../assets/divisor-04.webp';
import Box1Bg from '../../assets/Vector-3-1.svg';
import Box2Bg from '../../assets/Vector-2-1.svg';
---

<section class="extension-methodology">
  <Image 
    src={BgDivisor} 
    alt="" 
    class="bg-section-divisor" 
    loading="lazy" 
    decoding="async" 
  />

  <div class="container">
    <div class="absolute-ornament">
      <Image 
        src={Vector10}
        width="1252" height="88" alt="" loading="lazy" decoding="async" 
      />
    </div>

    <div class="methodology-box box-1">
      <Image 
        src={Box1Bg} 
        alt="" 
        class="box-bg" 
        loading="lazy" 
        decoding="async" 
      />
      
      <figure class="box-image">
        <Image 
          src={BluePin2}
          width="64" height="80" alt="" loading="lazy" decoding="async" 
        />
      </figure>
      <div class="box-content">
        <p>A TCC é uma abordagem voltada para soluções e oferece estratégias aplicáveis no dia a dia. É indicada em quadros ansiedade, depressão, fobias e outros desafios emocionais.</p>
      </div>
    </div>

    <div class="methodology-box box-2">
      <Image 
        src={Box2Bg} 
        alt="" 
        class="box-bg box-2-bg" 
        loading="lazy" 
        decoding="async" 
      />

      <figure class="box-image box-image-right">
        <Image 
          src={BluePin3} 
          width="64" height="80" alt="" loading="lazy" decoding="async" 
        />
      </figure>
      <div class="box-content">
        <p>No meu serviço, cada decisão clínica combina o que há de mais eficaz na pesquisa científica, minha experiência profissional e o que melhor se adapta às suas necessidades e valores.</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Seção Principal */
  .extension-methodology {
    position: relative;
    background-color: #1155B0;
    padding: 2% 3% 5% 3%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden; /* Garante que as bordas da imagem não vazem */
    /* Removidos: background-image, background-position, background-repeat, background-size */
  }

  /* Nova classe para simular o background-size: contain da seção */
  .bg-section-divisor {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain; 
    object-position: bottom center;
    z-index: 0;
    pointer-events: none;
  }

  .container {
    position: relative;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    width: 100%;
    max-width: 1140px;
    margin-bottom: 60px;
    z-index: 2; /* Garante que o container fique acima da bg-section-divisor */
  }

  /* Ornamento Absoluto (Vector-10) */
  .absolute-ornament {
    position: absolute;
    top: 0;
    right: 0;
    margin-top: -32px;
    padding: 0 50px 0 42px;
    pointer-events: none;
    z-index: 1;
  }

  /* Estilos Globais das Boxes */
  .methodology-box {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }

  /* Nova classe genérica para o fundo das duas Boxes (simulando background-size: cover) */
  .box-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    z-index: -1;
    pointer-events: none;
  }

  .methodology-box p {
    color: #F9F2EC;
    font-family: "Open Sans", sans-serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.4em;
    letter-spacing: 0.3px;
    margin: 0;
  }

  .box-image {
    margin: 0;
  }

  .box-image img {
    width: 40px;
    height: auto;
    display: block;
    transition-duration: 0.3s;
  }

  /* Box 1 (Esquerda) */
  .box-1 {
    width: 100%;
    max-width: 510px;
    padding: 8px 20px 30px 30px;
    text-align: left;
    /* Removidos: background-image, background-position, background-repeat, background-size */
  }

  .box-1 .box-image img {
    margin-left: -17px;
    margin-top: -10px;
  }

  /* Box 2 (Direita) */
  .box-2 {
    width: 100%;
    max-width: 500px;
    padding: 0 40px 30px 30px;
    align-self: flex-end;
    text-align: right;
    /* Removidos: background-image, background-position, background-repeat, background-size */
  }

  .box-image-right {
    display: flex;
    justify-content: flex-end;
  }

  .box-2 .box-image img {
    margin-right: -20px;
  }

  /* Responsivo - Tablet (até 1024px) */
  @media (max-width: 1024px) {
    .extension-methodology {
      padding-top: 50px;
      padding-bottom: 0;
      padding-left: 20px;
      padding-right: 20px;
    }

    .container {
      justify-content: center;
      gap: 40px; 
    }

    .absolute-ornament {
      display: none;
    }

    .box-1, .box-2 {
      align-self: center;
    }

    /* Ajusta a posição da imagem de fundo da Box 2 no mobile/tablet */
    .box-2-bg {
      object-position: bottom center;
    }
  }

  /* Responsivo - Mobile (até 767px) */
  @media (max-width: 767px) {
    .methodology-box p {
      font-size: 0.9em;
    }
  }
</style>