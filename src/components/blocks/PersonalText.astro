---
// src/components/PersonalText.astro
import OptimizedImage from '../OptimizedImage.astro'; // Importando a nossa Fonte Única de Verdade

// Imagens (Todas Raster - perfeitas para o nosso wrapper)
import DivisorImg from '../../assets/divisor.png';
import Vector11 from '../../assets/Vector-1-1.png';
import BgVector2 from '../../assets/bg-vector-2.webp';

// Nossos Componentes e Módulos Globais
import ButtonSolid from '../ButtonSolid.astro';
import { createWhatsAppUrl } from '../../utils/whatsapp';

const whatsappLink = createWhatsAppUrl("Olá, vim do site e gostaria de agendar uma consulta!");
---

<section class="personal-text-section">
  <OptimizedImage 
    src={DivisorImg} 
    alt="" 
    class="bg-section-divisor" 
    loading="lazy" 
    decoding="async" 
    aria-hidden="true" 
  />

  <div class="container">
    <h2 class="main-title">
      Com cuidado e parceria, vamos em direção a uma vida que vale a pena ser vivida.
    </h2>

    <div class="content-wrapper">
      <div class="text-block">
        <OptimizedImage 
          src={Vector11} 
          alt="" 
          class="bg-text-block" 
          loading="lazy" 
          decoding="async" 
          aria-hidden="true" 
        />
        <p>Todos passamos por dificuldades e enfrentamos nossas próprias batalhas, mas não precisamos enfrentá-las sozinhos.</p>
        
        <p>Nas sessões, enfrentaremos juntos os desafios diários, desenvolvendo <br/>
          <strong class="dest2">novas habilidades e padrões de pensamento e comportamento</strong> em busca do seu bem-estar emocional.
        </p>
        
        <p>O acompanhamento terapêutico pode te ajudar a enfrentar desafios e construir um caminho com mais tranquilidade, significado e propósito.</p>
        
        <p>O atendimento é 100% online, garantindo conforto, flexibilidade e o mesmo<br/>
          <strong class="dest2">compromisso ético</strong> com seu processo terapêutico.
        </p>
      </div>
    </div>

    <div class="cta-wrapper">
      <OptimizedImage 
        src={BgVector2} 
        alt="" 
        class="bg-cta" 
        loading="lazy" 
        decoding="async" 
        aria-hidden="true" 
      />
      <h2 class="cta-title">
        Estou por aqui para
        <span class="dest2">te auxiliar.</span>
      </h2>
      
      <ButtonSolid href={whatsappLink} class="cta-btn" />
    </div>
  </div>
</section>

<style>
  /* Container Principal */
  .personal-text-section {
    position: relative;
    background-color: var(--color-accent); /* Token Global */
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 0 0 140px;
  }

  /* Divisor */
  .bg-section-divisor {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    z-index: 0;
    pointer-events: none;
  }

  .container {
    max-width: 1140px;
    width: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1; 
  }

  /* Título Principal */
  .main-title {
    font-size: 51px;
    line-height: 1.1em;
    color: var(--color-bg-light); /* Token Global */
    text-align: center;
    margin: 0 auto;
    padding: 50px 20px;
  }

  /* Bloco de Texto Central */
  .content-wrapper {
    display: flex;
    justify-content: center;
    padding-bottom: 50px;
  }

  .text-block {
    position: relative; 
    padding: 70px 50px 90px 50px;
    max-width: 800px;
    text-align: justify;
    z-index: 1;
    
    /* Mantido para sobrescrever o estilo padrão de <p> do global.css */
    font-family: var(--font-heading);
    font-size: 20px;
    line-height: 1.45em;
    color: var(--color-bg-light);
    -webkit-text-stroke-color: #000;
    stroke: #000;
  }

  /* Fundo do bloco de texto */
  .bg-text-block {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: -8px -17px; 
    z-index: -1;
    pointer-events: none;
  }

  .text-block p {
    margin-bottom: 20px;
    font-weight: 700; /* Adicionado para deixar o texto em negrito (bold) */
  }

  /* Estilo do Marcador (Highlight) */
  .dest2 {
    background: #105FCB; /* Cor específica da seção */
    padding: 0px 4px;
    position: relative;
    z-index: 2;
    display: inline;
    border-left: 1px solid #95C0D0;
    border-right: 1px solid #95C0D0;
    margin-top: 8px;
    font-style: italic;
    /* Removido o font-weight: normal; para que o destaque herde o bold do parágrafo */
    -webkit-text-stroke: 0; 
  }

  .dest2::before,
  .dest2::after {
    position: absolute;
    content: "";
    background: #95C0D0;
    width: 6px;
    height: 6px;
    border-radius: 100px;
    z-index: 2;
    border: 0;
  }

  .dest2::before { top: -3px; left: -4px; }
  .dest2::after { bottom: -3px; right: -4px; }

  /* Seção Call To Action */
  .cta-wrapper {
    position: relative; 
    background-color: var(--color-accent); /* Token Global */
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px 30px 90px;
    margin: -30px; 
    border-radius: 15px; 
    overflow: hidden; 
    z-index: 1;
  }

  /* Fundo do CTA */
  .bg-cta {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    z-index: -1;
    pointer-events: none;
  }

  .cta-title {
    font-size: 38px;
    line-height: 1.2em;
    color: var(--color-bg-light); /* Token Global */
  }

  /* Responsividade (Mobile & Tablets) */
  @media (max-width: 1024px) {
    .personal-text-section {
      padding: 40px 20px 70px 20px;
    }
  }

  @media (max-width: 767px) {
    .main-title {
      font-size: 24px; 
      padding: 0px 40px;
    }

    .personal-text-section {
      padding: 50px 0px;
    }

    .content-wrapper {
      padding: 10px 40px;
    }

    .text-block {
      padding: 60px 10px;
      font-size: 14px;
      line-height: 1.1em;
      text-align: center;
    }

    .bg-text-block {
      object-position: -124px -1px;
    }

    .cta-wrapper {
      flex-direction: column;
      text-align: center;
      padding: 20px 0px 0px 0px;
      margin: 0px 0px 30px;
    }

    .bg-cta {
      width: 100%;
      height: 160px;
      left: 50%;
      transform: translateX(-50%);
      top: 0;
    }

    .cta-title {
      font-size: 24px;
      padding: 40px 10px;
      margin: 0;
    }

    /* Aplica a margem superior que o CTA precisa no celular e alinha */
    .cta-btn {
      margin-top: 50px;
    }
  }
</style>