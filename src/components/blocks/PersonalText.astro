---
// PersonalText.astro
import { Image } from 'astro:assets';

// Novas importações de imagens
import DivisorImg from '../../assets/divisor.png';
import Vector11 from '../../assets/Vector-1-1.png';
import BgVector2 from '../../assets/bg-vector-2.webp';
import BgBotao from '../../assets/bg-botao.webp';
---

<section class="personal-text-section">
  <Image 
    src={DivisorImg} 
    alt="" 
    class="bg-section-divisor" 
    loading="lazy" 
    decoding="async" 
    aria-hidden="true" 
  />

  <div class="container">
    <h2 class="main-title">
      Com cuidado e parceria, vamos em direção a uma vida que vale a pena ser vivida.
    </h2>

    <div class="content-wrapper">
      <div class="text-block">
        <Image 
          src={Vector11} 
          alt="" 
          class="bg-text-block" 
          loading="lazy" 
          decoding="async" 
          aria-hidden="true" 
        />
        <p>Todos passamos por dificuldades e enfrentamos nossas próprias batalhas, mas não precisamos enfrentá-las sozinhos.</p>
        
        <p>Nas sessões, enfrentaremos juntos os desafios diários, desenvolvendo <br/>
          <strong class="dest2">novas habilidades e padrões de pensamento e comportamento</strong> em busca do seu bem-estar emocional.
        </p>
        
        <p>O acompanhamento terapêutico pode te ajudar a enfrentar desafios e construir um caminho com mais tranquilidade, significado e propósito.</p>
        
        <p>O atendimento é 100% online, garantindo conforto, flexibilidade e o mesmo<br/>
          <strong class="dest2">compromisso ético</strong> com seu processo terapêutico.
        </p>
      </div>
    </div>

    <div class="cta-wrapper">
      <Image 
        src={BgVector2} 
        alt="" 
        class="bg-cta" 
        loading="lazy" 
        decoding="async" 
        aria-hidden="true" 
      />
      <h2 class="cta-title">
        Estou por aqui para
        <span class="dest2">te auxiliar.</span>
      </h2>
      
      <a 
        class="btn-whatsapp" 
        href="https://wa.me/5537998164092?text=Ol%C3%A1,%20vim%20do%20site%20e%20gostaria%20de%20agendar%20uma%20consulta!" 
        target="_blank" 
        rel="noopener noreferrer"
      >
        <Image 
          src={BgBotao} 
          alt="" 
          class="bg-btn-whatsapp" 
          loading="lazy" 
          decoding="async" 
          aria-hidden="true" 
        />
        <span class="btn-icon">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
          </svg>
        </span>
        <span class="btn-text">Agendar Minha Consulta</span>
      </a>
    </div>
  </div>
</section>

<style>
  /* Variáveis de estilo baseadas no seu tema */
  :root {
    --color-primary: #0B4491;
    --color-pink: #D94881;
    --color-white: #FFFFFF;
    --color-light: #F9F2EC;
    --color-highlight-bg: #105FCB;
    --color-highlight-border: #95C0D0;
    --font-heading: 'DM Serif Text', serif;
    --font-body: 'Open Sans', sans-serif;
  }

  /* Container Principal */
  .personal-text-section {
    position: relative; /* Adicionado */
    background-color: var(--color-pink);
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 0 0 140px;
    /* Removidos: background-image, background-position, background-repeat, background-size */
  }

  /* Nova classe: Divisor */
  .bg-section-divisor {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    z-index: 0;
    pointer-events: none;
  }

  .container {
    max-width: 1140px;
    width: 100%;
    display: flex;
    flex-direction: column;
    position: relative; /* Adicionado */
    z-index: 1; /* Adicionado para garantir que o texto fique acima do divisor */
  }

  /* Título Principal */
  .main-title {
    font-family: var(--font-heading);
    font-size: 51px;
    font-weight: 400;
    line-height: 1.1em;
    color: var(--color-white);
    text-align: center;
    margin: 0 auto;
    padding: 50px 20px 50px 20px;
  }

  /* Bloco de Texto Central */
  .content-wrapper {
    display: flex;
    justify-content: center;
    padding-bottom: 50px;
  }

  .text-block {
    position: relative; /* Adicionado */
    padding: 70px 50px 90px 50px;
    max-width: 800px;
    text-align: justify;
    z-index: 1;
    
    /* Tipografia exata do Elementor */
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.45em;
    color: var(--color-white);
    -webkit-text-stroke-color: #000;
    stroke: #000;
    /* Removidos: background-image, background-position, background-repeat, background-size */
  }

  /* Nova Classe: Fundo do bloco de texto */
  .bg-text-block {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: -8px -17px; /* Transferido do background-position */
    z-index: -1;
    pointer-events: none;
  }

  .text-block p {
    margin-bottom: 20px;
  }

  /* Estilo do Marcador (Highlight) Exato do Elementor */
  .dest2 {
    background: var(--color-highlight-bg);
    padding: 0px 4px;
    position: relative;
    z-index: 2;
    display: inline;
    border-left: 1px solid var(--color-highlight-border);
    border-right: 1px solid var(--color-highlight-border);
    margin-top: 8px;
    font-style: italic;
    font-weight: normal;
    -webkit-text-stroke: 0; /* Remove o stroke do texto destacado para legibilidade */
  }

  .dest2::before,
  .dest2::after {
    position: absolute;
    content: "";
    background: var(--color-highlight-border);
    width: 6px;
    height: 6px;
    border-radius: 100px;
    z-index: 2;
    border: 0;
  }

  .dest2::before {
    top: -3px;
    left: -4px;
  }

  .dest2::after {
    bottom: -3px;
    right: -4px;
  }

  /* Seção Call To Action */
  .cta-wrapper {
    position: relative; /* Adicionado */
    background-color: var(--color-pink);
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px 30px 90px;
    margin: -30px -30px -30px -30px; /* Compensação de bordas se necessário */
    border-radius: 15px; /* Adicionado um leve radius por estética moderna */
    overflow: hidden; /* Adicionado para que a imagem respeite o border-radius */
    z-index: 1;
    /* Removidos: background-image, background-position, background-repeat, background-size */
  }

  /* Nova Classe: Fundo do CTA */
  .bg-cta {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    z-index: -1;
    pointer-events: none;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: 38px;
    font-weight: 400;
    line-height: 1.2em;
    color: var(--color-light);
  }

  .btn-whatsapp {
    position: relative; /* Adicionado */
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 12px;
    background-color: transparent;
    padding: 20px 35px 20px 90px;
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-light);
    text-decoration: none;
    transition: filter 0.3s ease;
    z-index: 1;
    /* Removidos: background-image, background-size, background-position */
  }

  /* Nova Classe: Fundo do Botão WhatsApp */
  .bg-btn-whatsapp {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; /* Equivale ao background-size: cover */
    object-position: center;
    z-index: -1;
    pointer-events: none;
  }

  .btn-whatsapp:hover {
    filter: brightness(1.15);
  }

  .btn-icon svg {
    width: 24px;
    height: 24px;
  }

  /* Responsividade (Mobile & Tablets) */
  @media (max-width: 1024px) {
    .personal-text-section {
      padding: 40px 20px 70px 20px;
    }
  }

  @media (max-width: 767px) {
    .main-title {
      font-size: 24px; /* Adaptado do 1.5em */
      padding: 0px 40px;
    }

    .personal-text-section {
      padding: 50px 0px;
    }

    .content-wrapper {
      padding: 10px 40px;
    }

    .text-block {
      padding: 60px 10px;
      font-size: 14px;
      line-height: 1.1em;
      text-align: center;
    }

    /* Nova regra para o mobile do fundo do texto */
    .bg-text-block {
      object-position: -124px -1px;
    }

    .cta-wrapper {
      flex-direction: column;
      text-align: center;
      padding: 20px 0px 0px 0px;
      margin: 0px 0px 30px;
    }

    /* Nova regra para o mobile do fundo do CTA */
    /* Isso substitui perfeitamente seu "background-size: 180% 160px; background-position: top center;" */
    .bg-cta {
      width: 100%;
      height: 160px;
      left: 50%;
      transform: translateX(-50%);
      top: 0;
    }

    .cta-title {
      font-size: 24px;
      padding: 40px 10px;
      margin: 0;
    }

    .btn-whatsapp {
      margin-top: 50px;
      width: 70%;
      justify-content: center;
      padding: 20px 0 20px 40px;
      font-size: 16px;
    }
  }
</style>