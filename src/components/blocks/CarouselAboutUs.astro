---
// src/components/CarouselAboutUs.astro
import OptimizedImage from '../OptimizedImage.astro'; // Nossa fonte única de verdade
import Slide1 from '../../assets/row-1-column-1-818x1024.jpg';
import Slide2 from '../../assets/row-2-column-1-818x1024.jpg';
import Slide3 from '../../assets/3-818x1024.jpg';
import Slide4 from '../../assets/4-818x1024.jpg';
import Slide5 from '../../assets/5-818x1024.jpg';

const slides = [
  { src: Slide1, alt: "Foto Samuel 1" },
  { src: Slide2, alt: "Foto Samuel 2" },
  { src: Slide3, alt: "Foto Samuel 3" },
  { src: Slide4, alt: "Foto Samuel 4" },
  { src: Slide5, alt: "Foto Samuel 5" },
];
---

<about-carousel-widget>
  <section class="carousel-section">
    <div class="carousel-container">
      
      <button class="carousel-btn prev" aria-label="Slide anterior" disabled>
        <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M256 504C119 504 8 393 8 256S119 8 256 8s248 111 248 248-111 248-248 248zM142.1 273l135.5 135.5c9.4 9.4 24.6 9.4 33.9 0l17-17c9.4-9.4 9.4-24.6 0-33.9L226.9 256l101.6-101.6c9.4-9.4 9.4-24.6 0-33.9l-17-17c-9.4-9.4-24.6-9.4-33.9 0L142.1 239c-9.4 9.4-9.4 24.6 0 34z"></path>
        </svg>
      </button>

      <div class="carousel-track" id="about-carousel">
        {slides.map((slide, index) => (
          <div class="carousel-slide" data-index={index}>
            <figure>
              <OptimizedImage 
                src={slide.src} 
                alt={slide.alt} 
                loading="lazy"
                decoding="async"
                width={412} 
                height={516}              
                widths={[360, 412, 512, 720, slide.src.width]}
                sizes="(max-width: 767px) 100vw, (max-width: 1024px) 50vw, 33vw"
                class="carousel-img"
              />
            </figure>
          </div>
        ))}
      </div>

      <button class="carousel-btn next" aria-label="Próximo slide">
        <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M256 8c137 0 248 111 248 248S393 504 256 504 8 393 8 256 119 8 256 8zm113.9 231L234.4 103.5c-9.4-9.4-24.6-9.4-33.9 0l-17 17c-9.4 9.4-9.4 24.6 0 33.9L285.1 256 183.5 357.6c-9.4 9.4-9.4 24.6 0 33.9l17 17c9.4 9.4 24.6 9.4 33.9 0L369.9 273c9.4-9.4 9.4-24.6 0-34z"></path>
        </svg>
      </button>

    </div>

    <div class="carousel-pagination">
      {slides.map((_, index) => (
        <button 
          class={`dot ${index === 0 ? 'active' : ''}`} 
          data-target={index} 
          aria-label={`Ir para a página ${index + 1}`}>
        </button>
      ))}
    </div>
  </section>
</about-carousel-widget>

<style>
  /* Comportamento essencial para o Custom Element */
  about-carousel-widget {
    display: block;
    width: 100%;
  }

  .carousel-section { max-width: 100%; position: relative; }
  .carousel-container { position: relative; display: flex; align-items: center; overflow: hidden; }
  .carousel-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; scrollbar-width: none; width: 100%; }
  .carousel-track::-webkit-scrollbar { display: none; }
  .carousel-slide { flex: 0 0 calc(33.333%); scroll-snap-align: start; will-change: transform; }
  .carousel-slide figure { width: 100%; margin: 0; }
  
  .carousel-img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .carousel-btn { position: absolute; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; z-index: 10; padding: 0; display: flex; align-items: center; justify-content: center; opacity: 0.8; transition: opacity 0.3s ease; }
  .carousel-btn:hover:not(:disabled) { opacity: 1; }
  .carousel-btn:disabled { opacity: 0.2; cursor: not-allowed; pointer-events: none; }
  .carousel-btn svg { width: 40px; height: 40px; fill: #FFFFFF; filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.3)); }
  .prev { left: 10px; }
  .next { right: 10px; }
  
  .carousel-pagination { display: flex; justify-content: center; gap: 12px; margin-top: 20px; }
  .dot { width: 7px; height: 7px; border-radius: 50%; background-color: var(--color-primary); opacity: 0.3; border: none; cursor: pointer; padding: 0; transition: opacity 0.3s ease, transform 0.3s ease; }
  .dot.active { opacity: 1; transform: scale(1.2); }
  
  @media (min-width: 1025px) { .dot:nth-child(n+4) { display: none; } }
  @media (min-width: 768px) and (max-width: 1024px) { .dot:nth-child(n+5) { display: none; } }
  
  @keyframes elementorHint { 0% { transform: translate3d(0, 0, 0); } 50% { transform: translate3d(-25%, 0, 0); } 100% { transform: translate3d(0, 0, 0); } }
  .animate-hint .carousel-slide { animation: elementorHint 2s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
  
  @media (max-width: 1024px) { .carousel-slide { flex: 0 0 calc(50% - 5px); } }
  @media (max-width: 767px) { .carousel-slide { flex: 0 0 100%; } .carousel-btn svg { width: 25px; height: 25px; } .prev { left: 5px; } .next { right: 5px; } .carousel-section { margin-bottom:80px; } }
</style>

<script>
  class AboutCarousel extends HTMLElement {
    track: HTMLElement | null = null;
    prevBtn: HTMLButtonElement | null = null;
    nextBtn: HTMLButtonElement | null = null;
    dots: NodeListOf<HTMLElement> | null = null;
    observer: IntersectionObserver | null = null;

    isDown = false;
    startX = 0;
    scrollLeft = 0;
    cachedSlideWidth = 0;
    cachedClientWidth = 0;
    cachedScrollWidth = 0;
    isTicking = false;

    constructor() {
      super();
      this.updateDimensions = this.updateDimensions.bind(this);
      this.handleScrollUpdates = this.handleScrollUpdates.bind(this);
    }

    connectedCallback() {
      this.track = this.querySelector('.carousel-track');
      this.prevBtn = this.querySelector('.carousel-btn.prev');
      this.nextBtn = this.querySelector('.carousel-btn.next');
      this.dots = this.querySelectorAll('.dot');

      if (!this.track) return;

      this.setupEventListeners();
      this.setupIntersectionObserver();
      
      requestAnimationFrame(this.updateDimensions);
    }

    disconnectedCallback() {
      window.removeEventListener('resize', this.updateDimensions);
      if (this.observer && this.track) {
        this.observer.unobserve(this.track);
        this.observer.disconnect();
      }
    }

    setupEventListeners() {
      window.addEventListener('resize', () => {
        window.requestAnimationFrame(this.updateDimensions);
      }, { passive: true });

      this.track?.addEventListener('scroll', () => {
        if (!this.isTicking) {
          window.requestAnimationFrame(this.handleScrollUpdates);
          this.isTicking = true;
        }
      }, { passive: true });

      this.prevBtn?.addEventListener('click', () => {
        this.track?.scrollBy({ left: -this.cachedSlideWidth, behavior: 'smooth' });
      });

      this.nextBtn?.addEventListener('click', () => {
        this.track?.scrollBy({ left: this.cachedSlideWidth, behavior: 'smooth' });
      });

      this.dots?.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          const targetElement = e.target as HTMLElement;
          const targetIndex = parseInt(targetElement.getAttribute('data-target') || '0');
          this.track?.scrollTo({ left: targetIndex * this.cachedSlideWidth, behavior: 'smooth' });
        });
      });

      // Lógica de Drag
      this.track?.addEventListener('mousedown', (e) => {
        this.isDown = true;
        this.track!.style.scrollSnapType = 'none'; 
        this.startX = e.pageX - this.track!.offsetLeft;
        this.scrollLeft = this.track!.scrollLeft;
        this.track!.style.cursor = 'grabbing';
      });

      this.track?.addEventListener('mouseleave', () => this.endDrag());
      this.track?.addEventListener('mouseup', () => {
        this.endDrag();
        this.track?.scrollBy({ left: 1, behavior: 'smooth' }); 
      });

      this.track?.addEventListener('mousemove', (e) => {
        if (!this.isDown || !this.track) return;
        e.preventDefault();
        const x = e.pageX - this.track.offsetLeft; 
        const walk = (x - this.startX) * 1.5; 
        this.track.scrollLeft = this.scrollLeft - walk; 
      });
    }

    endDrag() {
      if (!this.isDown || !this.track) return;
      this.isDown = false;
      this.track.style.scrollSnapType = 'x mandatory';
      this.track.style.cursor = 'auto';
    }

    updateDimensions() {
      if (!this.track) return;
      const slide = this.track.querySelector('.carousel-slide') as HTMLElement;
      this.cachedSlideWidth = slide ? slide.offsetWidth : 0;
      this.cachedClientWidth = this.track.clientWidth;
      this.cachedScrollWidth = this.track.scrollWidth;
      this.handleScrollUpdates();
    }

    handleScrollUpdates() {
      if (this.cachedSlideWidth === 0 || !this.track) {
        this.isTicking = false;
        return;
      }

      const scrollPosition = this.track.scrollLeft;
      const maxScroll = this.cachedScrollWidth - this.cachedClientWidth;
      
      const isAtStart = scrollPosition <= 2;
      const isAtEnd = scrollPosition >= maxScroll - 2;
      
      const slidesPerView = Math.round(this.cachedClientWidth / this.cachedSlideWidth);
      const maxIndex = (this.dots?.length || 0) - slidesPerView;
      let currentIndex = Math.round(scrollPosition / this.cachedSlideWidth);
      if (currentIndex > maxIndex) currentIndex = maxIndex;

      requestAnimationFrame(() => {
        if (this.prevBtn) {
          isAtStart ? this.prevBtn.setAttribute('disabled', 'true') : this.prevBtn.removeAttribute('disabled');
        }

        if (this.nextBtn) {
          isAtEnd ? this.nextBtn.setAttribute('disabled', 'true') : this.nextBtn.removeAttribute('disabled');
        }

        this.dots?.forEach((dot, index) => {
          dot.classList.toggle('active', index === currentIndex);
        });
      });

      this.isTicking = false;
    }

    setupIntersectionObserver() {
      let animationExecuted = false; 
      this.observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (animationExecuted) return; 
          
          if (entry.isIntersecting && this.track) {
            animationExecuted = true; 
            this.track.classList.add('animate-hint');
            setTimeout(() => { this.track?.classList.remove('animate-hint'); }, 2500); 
            this.observer?.disconnect(); 
          }
        });
      }, { threshold: 0.6 });

      if (this.track) this.observer.observe(this.track);
    }
  }

  customElements.define('about-carousel-widget', AboutCarousel);
</script>