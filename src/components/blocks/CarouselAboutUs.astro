---
import OptimizedImage from '../OptimizedImage.astro';
import BaseCarousel from '../BaseCarousel.astro';

import Slide1 from '../../assets/CarouselAboutUs/prazer-samuel.jpg';
import Slide2 from '../../assets/CarouselAboutUs/cachorros-gatos.jpg';
import Slide3 from '../../assets/CarouselAboutUs/caminho-com-sentido.jpg';
import Slide4 from '../../assets/CarouselAboutUs/cognitivo-comportaamentais.jpg';
import Slide5 from '../../assets/CarouselAboutUs/vamos-conversar.jpg';

const slides = [
  { src: Slide1, alt: "Foto Samuel 1" },
  { src: Slide2, alt: "Foto Samuel 2" },
  { src: Slide3, alt: "Foto Samuel 3" },
  { src: Slide4, alt: "Foto Samuel 4" },
  { src: Slide5, alt: "Foto Samuel 5" },
];
---

<section class="about-section">
  <BaseCarousel itemCount={slides.length}>
    {slides.map((slide) => (
      <div class="carousel-slide">
        <figure>
          <OptimizedImage 
            src={slide.src} 
            alt={slide.alt} 
            loading="lazy"
            decoding="async"
            width={412} 
            height={516}            
            widths={[360, 412, 512, 720, slide.src.width]}
            sizes="(max-width: 767px) 100vw, (max-width: 1024px) 50vw, 33vw"
          />
        </figure>
      </div>
    ))}
  </BaseCarousel>
</section>

<style>
  .about-section { 
    max-width: 100%; 
    position: relative;
    margin-bottom: 0;
  }
  
  .carousel-slide { 
    flex: 0 0 calc(33.333%); 
    scroll-snap-align: start; 
    will-change: transform; 
  }
  
  .carousel-slide figure { 
    width: 100%; 
    margin: 0; 
  }
  
  .carousel-slide :global(img) { 
    width: 100%; 
    height: auto; 
    object-fit: cover; 
  }

  @media (max-width: 1024px) { 
    .carousel-slide { flex: 0 0 calc(50%); } 
  }
  
  @media (max-width: 767px) { 
    .about-section { margin-bottom: 80px; }
    .carousel-slide { flex: 0 0 100%; } 
  }
</style>