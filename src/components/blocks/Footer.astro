            <rect x="1.18145" y="1.19805" width="15.6899" height="16.6035" rx="7.84494" stroke="#0B4491" stroke-width="1.12071"></rect>
            <path d="M6.56326 12V5.8137H7.94173V12H6.56326ZM10.2868 12L8.48807 9.36074H10.001L11.8838 12H10.2868ZM7.57189 10.0332V8.94888H9.08485C9.28657 8.94888 9.46028 8.90965 9.60598 8.8312C9.75727 8.74715 9.87214 8.63228 9.95059 8.48659C10.0346 8.33529 10.0767 8.16158 10.0767 7.96546C10.0767 7.76933 10.0346 7.59843 9.95059 7.45273C9.87214 7.30144 9.75727 7.18657 9.60598 7.10812C9.46028 7.02406 9.28657 6.98204 9.08485 6.98204H7.57189V5.8137H8.97558C9.4855 5.8137 9.92818 5.89215 10.3036 6.04905C10.6791 6.20035 10.9676 6.42729 11.1694 6.72988C11.3711 7.03247 11.472 7.41351 11.472 7.873V8.00748C11.472 8.46137 11.3683 8.83961 11.161 9.1422C10.9592 9.43919 10.6706 9.66333 10.2952 9.81462C9.92538 9.96031 9.4855 10.0332 8.97558 10.0332H7.57189Z" fill="#0B4491"></path>
          </svg>
        </span>
        <span class="text">{currentYear} • Todos os direitos reservados</span>
      </li>

      <li>
        <a href="https://www.instagram.com/pinacria/" target="_blank" rel="noopener noreferrer">
          <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0C4491" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-template-icon lucide-layout-template"><rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/></svg>
          </span>
          <span class="text">Conceito inicial por @pinacria</span>
        </a>
      </li>

      <li>
        <a href="https://nelren.com.br" target="_blank" rel="noopener noreferrer">
          <span class="icon">
            <OptimizedImage 
              class="nelren" 
              src={Nelren} 
              alt="" 
              aria-hidden="true" 
              loading="lazy" 
            />
          </span>
          <span class="text">Desenvolvido por Nelren</span>
        </a>
      </li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-accent); 
    padding: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99;
    position: relative;
    width: 100%;
  }

  .footer-container {
    width: 100%;
    max-width: 1140px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 60px;
    list-style: none;
  }

  .footer-links li {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .footer-links a:hover {
    opacity: 0.8;
  }

  .footer-links .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 14px; 
    height: 14px;
  }

  .footer-links .icon :global(svg),
  .footer-links .icon :global(img) {
    width: 100%;
    height: auto;
    max-height: 14px;
    object-fit: contain; 
  }

  .footer-links .text {
    font-family: var(--font-heading); 
    font-size: 16px;
    font-weight: 400;
    color: #F9F2EC; 
    letter-spacing: 0.3px;
    line-height: 1.2;
  }

  @media (max-width: 1024px) {
    .footer-links {
      flex-direction: column;
      gap: 15px;
      text-align: center;
    }

    .footer-links li, .footer-links a {
      justify-content: center;
    }

    .footer-links .text {
      font-size: 14px;
    }
  }
</style>