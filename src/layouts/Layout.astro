---
import '../styles/global.css';

import '@fontsource/dm-serif-text';
import '@fontsource/open-sans';
import favIcon from '../assets/favicon.svg';

import fontDmSerif from '@fontsource/dm-serif-text/files/dm-serif-text-latin-400-normal.woff2?url';
import fontOpenSans from '@fontsource/open-sans/files/open-sans-latin-400-normal.woff2?url';

// Importando o novo componente
import GoogleTagManager from '../components/GoogleTagManager.astro';

const { title, description } = Astro.props;
const gtmId = import.meta.env.PUBLIC_GTM_ID;
---
<!doctype html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8" />
        
        <link rel="preload" href={fontDmSerif} as="font" type="font/woff2" crossorigin="anonymous">
        <link rel="preload" href={fontOpenSans} as="font" type="font/woff2" crossorigin="anonymous">

        <GoogleTagManager />
        
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href={favIcon.src} />
        <title>{title}</title>
    </head>
    <body>       
        {gtmId && (
          <noscript>
            <iframe 
              src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
              height="0" width="0" style="display:none;visibility:hidden">
            </iframe>
          </noscript>
        )}
        
        <slot />
    </body>
</html>